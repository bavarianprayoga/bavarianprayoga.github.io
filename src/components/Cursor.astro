---
---

<div class="cursor" id="cursor"></div>

<style>
  .cursor {
    border-radius: 50px;
    width: 12px;
    height: 12px;
    border: 1px solid #FFFFE3;
    box-sizing: border-box;
    position: fixed;
    top: 50%;
    left: 10%;
    transform: translate(-50%, -50%) rotate(0deg);
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: difference;
    background-color: #FFFFE3;
    transition: width 0.05s ease, height 0.05s ease;
  }
</style>


<script>
  import { gsap } from "gsap";

  const element = document.querySelector(".cursor");
  
  class Cursor {
    el: Element;
    currentTarget: Element | null = null;
    
    constructor(el: Element) {
      this.el = el;
      this.bind();
    }

    bind() {
      document.addEventListener("mousemove", this.move.bind(this), false);
    }

    move(e: MouseEvent) {
      const cursorPosition = {
        left: e.clientX,
        top: e.clientY
      };
      
      let isHoveringTarget = false;
      const triggerDistance = 50; // Configurable trigger distance
      const hoverSize = 65; // The fixed size of the cursor when attached

      const links = document.querySelectorAll("a, button");
      let hoveredLink: Element | null = null;
      for (const single of links) {
        const rect = single.getBoundingClientRect();
        
        const targetPosition = {
          left: rect.left + rect.width / 2,
          top: rect.top + rect.height / 2
        };
        const distance = {
          x: targetPosition.left - cursorPosition.left,
          y: targetPosition.top - cursorPosition.top
        };

        const angle = Math.atan2(distance.x, distance.y);
        const hypotenuse = Math.sqrt(
          distance.x * distance.x + distance.y * distance.y
        );
        
        if (hypotenuse < triggerDistance) {
          isHoveringTarget = true;
          hoveredLink = single;
          gsap.to(this.el, {
            duration: 0.2,
            left: targetPosition.left - (Math.sin(angle) * hypotenuse) / 2,
            top: targetPosition.top - (Math.cos(angle) * hypotenuse) / 2,
            height: hoverSize,
            width: hoverSize
          });
          break; // Stop checking other links once we're attached to one
        }
      }

      if (hoveredLink !== this.currentTarget) {
        if (this.currentTarget) {
          this.currentTarget.classList.remove('cursor-hover');
        }
        if (hoveredLink) {
          hoveredLink.classList.add('cursor-hover');
        }
        this.currentTarget = hoveredLink;
      }

      if (!isHoveringTarget) {
        gsap.to(this.el, {
          duration: 0.2,
          left: cursorPosition.left,
          top: cursorPosition.top,
          height: 12,
          width: 12
        });
      }
    }
  }
  
  const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;

  if (element && !isTouchDevice) {
    new Cursor(element);
  } else if (element) {
    (element as HTMLElement).style.display = 'none';
  }
</script>